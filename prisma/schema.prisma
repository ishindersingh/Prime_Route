generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

model Booking {
  id        String   @id @default(cuid())
  name      String
  phone     String
  date      String
  time      String
  pickup    String
  dropoff   String
  service   String
  status    String   @default("pending")
  createdAt DateTime @default(now())
}
